{
  "name": "hono-middleware-tracer",
  "version": "1.0.0",
  "description": "OpenTelemetry instrumentation package producing traces for hono middlewares",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "require": "./dist/register.cjs",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "prepare": "pnpm build"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "hono",
    "middleware",
    "trace"
  ],
  "author": "baloo",
  "license": "ISC",
  "packageManager": "pnpm@10.22.0",
  "peerDependencies": {
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@hono/zod-openapi": "^1.2.2",
    "@types/node": "^25.3.3",
    "hono": "^4.12.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "tsup": {
    "format": [
      "esm",
      "cjs"
    ],
    "dts": {
      "resolve": true,
      "entry": [
        "./src/index.ts",
        "./src/register.ts"
      ]
    },
    "clean": true,
    "target": "esnext",
    "entry": [
      "./src/index.ts",
      "./src/register.ts"
    ]
  }
}