{
  "name": "hono-middleware-tracer",
  "version": "1.1.3",
  "description": "OpenTelemetry instrumentation package producing traces for hono middlewares",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "type": "module",
  "files": [
    "./dist/**"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cs-balazs/hono-middleware-tracer"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "require": "./dist/register.cjs",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "prepare": "pnpm build"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "hono",
    "middleware",
    "trace"
  ],
  "author": "baloo",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@hono/zod-openapi": "^1.2.4",
    "@types/node": "^25.6.0",
    "hono": "^4.12.12",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "tsup": {
    "format": [
      "esm",
      "cjs"
    ],
    "dts": {
      "resolve": true,
      "entry": [
        "./src/index.ts",
        "./src/register.ts"
      ],
      "compilerOptions": {
        "ignoreDeprecations": "6.0"
      }
    },
    "clean": true,
    "target": "esnext",
    "entry": [
      "./src/index.ts",
      "./src/register.ts"
    ]
  }
}